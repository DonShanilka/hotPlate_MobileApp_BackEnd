{
  "info": {
    "name": "HotPlate – Order API",
    "_postman_id": "hotplate-order-api",
    "description": "Complete Order module endpoints for the HotPlate backend.\n\nBase URL: http://192.168.1.101:3000/api/order\n\nAuthenticated routes require the Bearer token from the login response.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://192.168.1.101:3000/api/order",
      "type": "string"
    },
    {
      "key": "token",
      "value": "PASTE_YOUR_JWT_TOKEN_HERE",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "PASTE_ORDER_ID_HERE",
      "type": "string"
    },
    {
      "key": "driverId",
      "value": "PASTE_DRIVER_ID_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "📦 Place New Order (Mobile Client)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"address\": \"123 Main Street, Colombo 03\",\n  \"phoneNumber\": \"0771234567\",\n  \"totalPrice\": 1850,\n  \"items\": [\n    {\n      \"name\": \"Chicken Burger\",\n      \"size\": \"Large\",\n      \"quantity\": 2,\n      \"price\": 650\n    },\n    {\n      \"name\": \"Fries\",\n      \"size\": \"Medium\",\n      \"quantity\": 1,\n      \"price\": 350\n    },\n    {\n      \"name\": \"Coke\",\n      \"quantity\": 2,\n      \"price\": 100\n    }\n  ],\n  \"paymentMethod\": \"CASH\",\n  \"notes\": \"Extra napkins please\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/AddOrder",
          "host": ["{{baseUrl}}"],
          "path": ["AddOrder"]
        }
      },
      "response": []
    },
    {
      "name": "📋 Get All Orders (Admin)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/getAll",
          "host": ["{{baseUrl}}"],
          "path": ["getAll"],
          "query": [
            { "key": "status", "value": "PENDING", "disabled": true },
            { "key": "userId", "value": "USER_ID", "disabled": true },
            { "key": "restaurantId", "value": "RESTAURANT_ID", "disabled": true },
            { "key": "driverId", "value": "DRIVER_ID", "disabled": true }
          ]
        }
      },
      "response": []
    },
    {
      "name": "🔍 Get Order By ID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/getById/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["getById", "{{orderId}}"]
        }
      },
      "response": []
    },
    {
      "name": "👤 Get My Orders (Logged-in User)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/myOrders",
          "host": ["{{baseUrl}}"],
          "path": ["myOrders"]
        }
      },
      "response": []
    },
    {
      "name": "🔄 Update Order Status",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"CONFIRMED\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/status/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["status", "{{orderId}}"]
        }
      },
      "response": [],
      "_postman_comments": "Valid status values: PENDING | CONFIRMED | PREPARING | READY_FOR_PICKUP | OUT_FOR_DELIVERY | DELIVERED | CANCELLED"
    },
    {
      "name": "🚴 Assign Driver to Order",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"driverId\": \"{{driverId}}\",\n  \"estimatedDeliveryTime\": 30\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/assign-driver/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["assign-driver", "{{orderId}}"]
        }
      },
      "response": []
    },
    {
      "name": "💳 Update Payment Status",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"paymentStatus\": \"PAID\",\n  \"paymentMethod\": \"CASH\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/payment/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["payment", "{{orderId}}"]
        }
      },
      "response": [],
      "_postman_comments": "Valid paymentStatus: UNPAID | PAID | REFUNDED. Valid paymentMethod: CASH | CARD | ONLINE"
    },
    {
      "name": "❌ Cancel Order",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/cancel/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["cancel", "{{orderId}}"]
        }
      },
      "response": [],
      "_postman_comments": "Only PENDING or CONFIRMED orders can be cancelled."
    },
    {
      "name": "🗑️ Delete Order (Admin)",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/delete/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["delete", "{{orderId}}"]
        }
      },
      "response": []
    }
  ]
}
